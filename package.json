{
  "name": "@sigureya/rpgmakerschema",
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "main": "dist/rpg-data-tools.cjs.js",
  "module": "dist/rpg-data-tools.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/RmmzPluginSchema.cjs.js",
      "import": "./dist/RmmzPluginSchema.es.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sigureya/RpgMakerSchema"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "format": "prettier --write .",
    "lint": " eslint . --ext .ts,.tsx"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^9.21.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.11",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^2.1.9"
  }
}
